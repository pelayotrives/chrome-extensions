{
  "manifest_version": 3,
  "name": "Extensio Patronus",
  "description": "Organize, toggle, and restore your Chrome extensions from one clean popup.",
  "version": "0.1.0",
  "permissions": ["management", "storage", "tabs"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Extensio Patronus",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup/popup.html"
  }
}
